{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.sutures.dev/v1.json",
  "title": "Sutures DSL V1",
  "description": "Declarative field mapping between JSON payloads and typed structures",
  "type": "object",
  "required": ["name", "suture_sets"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "suture_sets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/SutureSet"
      }
    }
  },
  "additionalProperties": false,

  "$defs": {
    "SutureSet": {
      "type": "object",
      "required": ["name", "capture", "sutures"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "capture": {
          "type": "string",
          "enum": ["request", "response"]
        },
        "sutures": {
          "type": "array"
        }
      },
      "additionalProperties": false,
      "if": {
        "properties": { "capture": { "const": "request" } }
      },
      "then": {
        "properties": {
          "sutures": { "items": { "$ref": "#/$defs/request_suture" } }
        }
      },
      "else": {
        "properties": {
          "sutures": { "items": { "$ref": "#/$defs/response_suture" } }
        }
      }
    },

    "json_terminal": {
      "type": "string",
      "pattern": "^/[A-Za-z0-9_$.\\[\\]:?/`^()\\-+\\\\*|]*$"
    },

    "struct_terminal": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_$.\\[\\]:?/`^()\\-+\\\\*|]*$"
    },

    "request_suture": {
      "type": "object",
      "propertyNames": {
        "oneOf": [{ "const": "_" }, { "$ref": "#/$defs/struct_terminal" }]
      },
      "additionalProperties": {
        "oneOf": [
          { "$ref": "#/$defs/json_terminal" },
          {
            "type": "array",
            "items": { "$ref": "#/$defs/json_terminal" },
            "minItems": 1
          },
          { "$ref": "#/$defs/request_suture" }
        ]
      },
      "properties": {
        "_": {
          "type": "array",
          "items": {
            "type": "object",
            "minProperties": 1,
            "maxProperties": 1,
            "propertyNames": { "$ref": "#/$defs/json_terminal" },
            "additionalProperties": {
              "oneOf": [
                { "type": "string" },
                { "type": "number" },
                { "type": "boolean" },
                { "type": "null" }
              ]
            }
          }
        }
      }
    },

    "response_suture": {
      "type": "object",
      "propertyNames": {
        "oneOf": [{ "const": "_" }, { "$ref": "#/$defs/json_terminal" }]
      },
      "additionalProperties": {
        "oneOf": [
          { "$ref": "#/$defs/struct_terminal" },
          {
            "type": "array",
            "items": { "$ref": "#/$defs/struct_terminal" },
            "minItems": 1
          },
          { "$ref": "#/$defs/response_suture" }
        ]
      },
      "properties": {
        "_": {
          "type": "array",
          "items": {
            "type": "object",
            "minProperties": 1,
            "maxProperties": 1,
            "propertyNames": { "$ref": "#/$defs/struct_terminal" },
            "additionalProperties": {
              "oneOf": [
                { "type": "string" },
                { "type": "number" },
                { "type": "boolean" },
                { "type": "null" }
              ]
            }
          }
        }
      }
    }
  }
}
